# PostgreSQL
# For Supabase on IPv4-only networks, use the Supavisor pooler connection string
# from the dashboard Connect panel instead of the direct db.<project-ref>.supabase.co host.
# Production deploys should only run `npm run db:migrate`.
# Never point DATABASE_URL at production when doing local reset/seed work.
DATABASE_URL="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/YOUR_DB_NAME?sslmode=require"

# App
APP_SECRET="replace_with_a_long_random_secret_key"
APP_BASE_URL="http://localhost:3000"
NODE_ENV="development"
# Optional explicit app environment. Falls back to NODE_ENV when unset.
APP_ENV="development"

# Destructive DB tooling is blocked in production and requires all of:
# - ALLOW_DESTRUCTIVE_DB_COMMANDS=true
# - DATABASE_URL resolving to an allowlisted database name
# - --confirm <exact_db_name> on the command line
# Local/test only commands: `npm run db:reset:dev` and `npm run db:seed:dev`
ALLOW_DESTRUCTIVE_DB_COMMANDS="false"
ALLOW_PRODUCTION_ROLLBACK="false"
DEV_DB_NAME_ALLOWLIST="printflow_dev,printflow_test"

# Session
SESSION_COOKIE_NAME="dlms_session"
SESSION_MAX_AGE="604800"

# Session activity window in minutes
ACTIVE_USER_WINDOW_MINUTES="15"
