# PostgreSQL
# For Supabase on IPv4-only networks, use the Supavisor pooler connection string
# from the dashboard Connect panel instead of the direct db.<project-ref>.supabase.co host.
DATABASE_URL="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/YOUR_DB_NAME?sslmode=require"

# App
APP_SECRET="replace_with_a_long_random_secret_key"
APP_BASE_URL="http://localhost:3000"
NODE_ENV="development"

# Session
SESSION_COOKIE_NAME="dlms_session"
SESSION_MAX_AGE="604800"
