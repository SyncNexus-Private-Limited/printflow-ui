{
  "name": "printflow-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:new": "node scripts/db/new-migration.mjs",
    "db:migrate": "node scripts/db/migrate.mjs",
    "db:rollback": "node scripts/db/rollback.mjs",
    "db:dump": "node scripts/db/dump.mjs",
    "db:seed:dev": "node scripts/db/seed-dev.mjs",
    "db:reset:dev": "node scripts/db/reset-dev.mjs",
    "db:target": "node scripts/db/target.mjs",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@opennextjs/cloudflare": "^1.19.11",
    "jose": "^6.1.0",
    "lucide-react": "^1.8.0",
    "next": "^15.5.14",
    "pg": "^8.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.65.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24.7.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.15",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "prettier-plugin-sql": "^0.20.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.94.0"
  }
}
